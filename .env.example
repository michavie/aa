# ── Network
MULTIVERSX_API_URL=https://api.battleofnodes.com
CHAIN_ID=BON-1

# ── Announced at 15:00 UTC on challenge day — fill in before 16:00
ADMIN_WALLET_ADDRESS=erd1...
TARGET_WALLET_ADDRESS=erd1...

# ── Guild leader wallet (receives 500 EGLD, funds agents)
GL_PRIVATE_KEY_HEX=your64charhexkey

# ── Registry contract (MX-8004)
IDENTITY_REGISTRY_ADDRESS=erd1qqqqqqqqqqqqqpgq4mar8ex8aj2gnc0cq7ay372eqfd5g7t33frqcg776p

# ── Google Gemini for semantic command interpretation
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key

# ── Tuning (optional)
NUM_AGENTS=10
EGLD_PER_AGENT=40000000000000000000
POLL_INTERVAL_MS=300
SEND_BATCH_SIZE=8
SEND_INTERVAL_MS=80
