# GL wallet PEM file (default: ./gl.pem)
# For testing : run `npm run wallet` to generate a fresh gl.pem
# For live    : replace gl.pem with your real guild leader wallet PEM
# GL_PEM_FILE=./gl.pem   ← optional override if file is elsewhere

# Announced at 15:00 UTC on challenge day — add before starting agents
ADMIN_WALLET_ADDRESS=erd1...
TARGET_WALLET_ADDRESS=erd1...

# Google Gemini — semantic command interpretation
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key

# Optional: simulator admin wallet (for local testing with npm run simulate)
SIMULATE_ADMIN_KEY=your64charhexkey
